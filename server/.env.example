# Server environment configuration for Render deployment

# Database - Use MongoDB Atlas connection string
DATABASE_URL=mongodb+srv://username:password@your-cluster.mongodb.net/railway-track?retryWrites=true&w=majority

# Server configuration
PORT=3000
NODE_ENV=production
SERVER_BASE_URL=https://railway-track-backend.onrender.com

# Frontend URL for redirect/CORS
CLIENT_URL=https://railway-track.onrender.com
CORS_ORIGIN=https://railway-track.onrender.com

# Security
JWT_SECRET=your-super-secure-secret-key-change-this-to-random-string-12345
JWT_EXPIRES_IN=7d

# AI Service
AI_SERVICE_URL=https://railway-track-ai.onrender.com

# UDM Integration (optional - update with your keys)
UDM_API_URL=https://www.ireps.gov.in/api
UDM_API_KEY=your-udm-api-key

# TMS Integration (optional - update with your keys)
TMS_API_URL=https://www.irecept.gov.in/api
TMS_API_KEY=your-tms-api-key

# Station Search API (optional)
STATION_API_URL=
STATION_API_KEY=

# QR Code Settings
QR_CODE_SIZE=200
QR_CODE_ERROR_CORRECTION_LEVEL=M

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=/tmp/uploads

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
